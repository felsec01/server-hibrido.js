# Porta (Render já injeta automaticamente, não precisa definir)
# PORT=3000

# URLs permitidas para CORS e WebSocket (separadas por vírgula)
ALLOWED_ORIGINS=https://clean-helmet.onrender.com,https://clean-helmet.netlify.app,http://localhost:3000

# Nível de log (info, warn, error, debug)
LOG_LEVEL=info

# Limite de requisições (rate limiting)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# Token do Mercado Pago (substitua pelo seu)
MERCADOPAGO_ACCESS_TOKEN=TEST-APP_USR-4503042088690361-072313-1e17fdf654ba9aeea3c9065e650f0e06-21917910

# Ambiente (development ou production)
NODE_ENV=production
